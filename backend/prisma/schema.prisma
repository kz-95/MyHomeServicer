// My Home Servicer — Prisma schema
// Single source of truth for the database. 49 models (48 domain + 1 infrastructure) across 13 domain blocks.
// UUID PKs (gen_random_uuid()) throughout. Decimal(10,2) for all money.
// Soft deletes on User, Servicer, ServicerService, Category.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────────────────────────

enum Role {
  customer
  admin
}

enum TimeSlot {
  morning
  noon
  afternoon
  evening
  night
}

enum Weekday {
  mon
  tue
  wed
  thu
  fri
  sat
  sun
}

enum DevicePlatform {
  ios
  android
  web
}

enum OtpPurpose {
  password_reset
  phone_verify
}

enum KycStatus {
  pending
  approved
  rejected
}

enum PriceType {
  fixed
  hourly
  quote
}

enum TaxMode {
  inclusive
  exclusive
  none
}

enum PenaltyType {
  noshow
  cancel
}

enum PenaltyCalcMode {
  fixed
  percentage
}

enum PenaltyStatus {
  applied
  reversed
}

enum AppealStatus {
  pending
  approved
  rejected
}

enum DeadlineMode {
  fcfs
  fixed_time
}

enum PaymentMode {
  pay_now
  pay_later
  cash
}

enum QuoteStatus {
  open
  pending_payment
  matched
  expired
  cancelled
  reposted
}

enum ProposalStatus {
  submitted
  selected
  rejected
}

enum BookingStatus {
  pending_confirm
  confirmed
  in_progress
  completed
  cancelled
}

enum MutualCancelStatus {
  pending
  accepted
  rejected
}

enum TipStatus {
  pending
  paid
}

enum EscrowStatus {
  held
  released
  refunded
}

enum TransactionType {
  escrow_hold
  escrow_release
  refund
  tip
  penalty
  deposit
  discount
  platform_fee
  urgent_fee
  promo_payback
  withdrawal
  gateway_payment
  deposit_topup
  gateway_fee
  registered_customer_discount
  promo_cost
  points_liability
}

enum TransactionStatus {
  pending
  completed
  failed
}

enum DiscountType {
  percent
  fixed
}

enum ReportStatus {
  open
  resolved
}

enum JobStatus {
  queued
  active
  completed
  failed
}

enum ChatContextType {
  general
  booking_support
  quote_help
}

enum ChatRole {
  user
  assistant
}

enum CreditLogType {
  promo_payback
  withdrawal
  manual_adjustment
}

enum WithdrawalStatus {
  pending
  approved
  paid
  rejected
}

enum CategoryRequestStatus {
  pending
  approved
  rejected
}

enum PromotionOwnerType {
  platform
  servicer
}

enum PromotionScope {
  all
  category
  service
}

enum DocType {
  ic_front
  ic_back
  selfie
  supporting
}

enum FileStatus {
  pending
  confirmed
}

enum OrderHistoryType {
  service
  category
}

enum EntityType {
  sole_proprietorship
  partnership
  enterprise
  sdn_bhd
}

enum PaymentTiming {
  pay_now
  pay_later
}

enum SettlementMethod {
  gateway
  credit
  cash
}

enum IdentityRequestStatus {
  pending
  approved
  rejected
}

// ──────────────────────────────────────────────────────────────────────────────
// Block 1 — Users & auth
// ──────────────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role              Role      @default(customer)
  name              String
  email             String    @unique
  phone             String
  passwordHash      String?   @map("password_hash")
  googleId          String?   @unique @map("google_id")
  contactName       String?   @map("contact_name")
  contactNumber     String?   @map("contact_number")
  preferredTimeSlot TimeSlot? @map("preferred_time_slot")
  actionPinHash     String?   @map("action_pin_hash") // admin only
  creditBalance     Decimal   @default(0) @map("credit_balance") @db.Decimal(10, 2)
  // Notification settings — { types: {orders,jobs,listings,promos,...}, followedCategoryIds: [] }
  notificationPrefs Json?     @map("notification_prefs")
  bio              String?   @map("bio")
  avatarUrl         String?   @map("avatar_url")
  isDemo            Boolean   @default(false) @map("is_demo")
  passwordChangedAt DateTime?  @map("password_changed_at")
  backupEmail       String?    @map("backup_email")
  failedLoginCount  Int       @default(0) @map("failed_login_count")
  lockedUntil       DateTime? @map("locked_until")
  chatBanned        Boolean   @default(false) @map("chat_banned")
  chatStrikeCount   Int       @default(0) @map("chat_strike_count")
  deletedAt         DateTime? @map("deleted_at")
  active            Boolean   @default(true) @map("active")
  deactivationCount Int       @default(0) @map("deactivation_count")
  deactivatedAt     DateTime? @map("deactivated_at")
  resetToken        String?   @unique @map("reset_token")
  resetTokenExpiry  DateTime? @map("reset_token_expiry")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  addresses      UserAddress[]
  quotePresets   QuotePreset[]
  devices        UserDevice[]
  refreshTokens  RefreshToken[]
  otpCodes      OtpCode[]
  notifications Notification[]
  quoteRequests QuoteRequest[]
  bookings      Booking[]
  orderHistory  OrderHistory[]
  reports       Report[]
  chatSessions  ChatSession[]
  savedPayments  SavedPaymentMethod[] @relation("UserSavedPaymentMethods")
  transactions   Transaction[]         @relation("UserTransactions")

  customerPoints     CustomerPoints?
  pointsTransactions PointsTransaction[]
  redemptions        Redemption[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model UserAddress {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  label        String
  address      String
  propertyType String?  @map("property_type")
  lat          Float?
  lng          Float?
  postcode     String?  @map("postcode")
  district     String?  @map("district")
  state        String?  @map("state")
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user          User           @relation(fields: [userId], references: [id])
  quoteRequests QuoteRequest[]
  quotePresets  QuotePreset[]

  @@index([userId])
  @@map("user_addresses")
}

// Saved quote presets — a customer keeps up to 10 reusable bundles of quote
// details (contact, address, instruction, preferred time) to pick from when
// submitting a quote, instead of re-entering everything each time.
model QuotePreset {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  label             String?
  contactName       String    @map("contact_name")
  contactNumber     String    @map("contact_number")
  addressId         String    @map("address_id") @db.Uuid
  instruction       String?
  preferredTimeSlot TimeSlot?  @map("preferred_time_slot")
  isDefault         Boolean    @default(false) @map("is_default")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  user    User        @relation(fields: [userId], references: [id])
  address UserAddress @relation(fields: [addressId], references: [id])

  @@index([userId])
  @@map("quote_presets")
}

model UserDevice {
  id          String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String         @map("user_id") @db.Uuid
  deviceToken String         @map("device_token")
  platform    DevicePlatform
  isActive    Boolean        @default(true) @map("is_active")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("user_devices")
}

model RefreshToken {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  servicerId String?   @map("servicer_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  deviceId   String?   @map("device_id")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id])
  servicer Servicer? @relation(fields: [servicerId], references: [id])

  @@index([userId])
  @@index([servicerId])
  @@map("refresh_tokens")
}

model OtpCode {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String     @map("user_id") @db.Uuid
  codeHash   String     @map("code_hash")
  purpose    OtpPurpose
  expiresAt  DateTime   @map("expires_at")
  consumedAt DateTime?  @map("consumed_at")
  createdAt  DateTime   @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, purpose])
  @@map("otp_codes")
}

model Notification {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  // Exactly one of userId / servicerId is set — notifications now target
  // customers, servicers and admins (admins are USER rows with role=admin).
  userId        String?  @map("user_id") @db.Uuid
  servicerId    String?  @map("servicer_id") @db.Uuid
  type          String
  message       String
  // Generic in-app redirect target for a click (e.g. /customer/quotes/<id>).
  linkUrl       String?  @map("link_url")
  // Optional category tag, used by the notification list filter.
  category      String?
  linkQuoteList String?  @map("link_quote_list")
  linkReorder   String?  @map("link_reorder")
  isRead        Boolean  @default(false) @map("is_read")
  createdAt     DateTime @default(now()) @map("created_at")

  user     User?     @relation(fields: [userId], references: [id])
  servicer Servicer? @relation(fields: [servicerId], references: [id])

  @@index([userId, isRead])
  @@index([servicerId, isRead])
  @@map("notifications")
}

// ──────────────────────────────────────────────────────────────────────────────
// Block 2 — Servicer
// ──────────────────────────────────────────────────────────────────────────────

model Servicer {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                       String
  email                      String    @unique
  phone                      String
  passwordHash               String?   @map("password_hash")
  pinHash                    String?   @map("pin_hash")
  showEmailPublic            Boolean   @default(false) @map("show_email_public")
  showPhonePublic            Boolean   @default(false) @map("show_phone_public")
  invoiceContent             String?   @map("invoice_content")
  invoiceSuffix              String?   @map("invoice_suffix")
  googleId                   String?   @unique @map("google_id")
  businessName               String    @map("business_name")
  bio                        String?
  logoUrl                    String?   @map("logo_url")
  isCompany                  Boolean   @default(false) @map("is_company")
  taxNumber                  String?   @map("tax_number")
  businessRegistrationNumber String?   @map("business_registration_number")
  entityType                 EntityType?
  sstRegistered              Boolean   @default(false) @map("sst_registered")
  sstNumber                  String?   @map("sst_number")
  serviceChargeRate          Decimal   @default(0) @db.Decimal(5, 4) @map("service_charge_rate")
  taxInclusive               Boolean   @default(false) @map("tax_inclusive")
  serviceAreas               String[]  @map("service_areas")
  serviceRadiusKm            Int       @default(10) @map("service_radius_km")
  lat                        Float?    @map("lat") @db.DoublePrecision
  lng                        Float?    @map("lng") @db.DoublePrecision
  operatingHours             Json      @default("[]") @map("operating_hours")
  categoryId                 String    @map("category_id") @db.Uuid
  isOnline                   Boolean   @default(true) @map("is_online")
  kycStatus                  KycStatus @default(approved) @map("kyc_status")
  bankName                   String?   @map("bank_name")
  bankAccount                String?   @map("bank_account")
  onboarded                  Boolean   @default(false) @map("onboarded")
  creditBalance              Decimal   @default(0) @map("credit_balance") @db.Decimal(10, 2)
  maxAutoAccepts             Int       @default(3) @map("max_auto_accepts")
  invoicePrefix              String    @default("INV") @map("invoice_prefix")
  invoiceYearFormat          String    @default("YYYY") @map("invoice_year_format")
  invoiceSeparator           String    @default("-") @map("invoice_separator")
  invoicePadding             Int       @default(4) @map("invoice_padding")
  invoiceNextNumber          Int       @default(1) @map("invoice_next_number")
  rating                     Float     @default(0)
  isBanned                   Boolean   @default(false) @map("is_banned")
  chatBanned                 Boolean   @default(false) @map("chat_banned")
  chatStrikeCount            Int       @default(0) @map("chat_strike_count")
  weeklyNoshow               Int       @default(0) @map("weekly_noshow")
  consecutiveNoshow          Int       @default(0) @map("consecutive_noshow")
  // Notification settings — same shape as User.notificationPrefs.
  notificationPrefs          Json?     @map("notification_prefs")
  isDemo                     Boolean   @default(false) @map("is_demo")
  failedLoginCount           Int       @default(0) @map("failed_login_count")
  lockedUntil                DateTime? @map("locked_until")
  deletedAt                  DateTime? @map("deleted_at")
  active                     Boolean   @default(true) @map("active")
  deactivationCount          Int       @default(0) @map("deactivation_count")
  deactivatedAt              DateTime? @map("deactivated_at")
  resetToken                 String?   @unique @map("reset_token")
  resetTokenExpiry           DateTime? @map("reset_token_expiry")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  category         Category               @relation("ServicerCategory", fields: [categoryId], references: [id])
  deposit          ServicerDeposit?
  documents        ServicerDocument[]
  schedules        ServicerSchedule[]
  services         ServicerService[]
  refreshTokens    RefreshToken[]
  penaltyLogs      PenaltyLog[]
  penaltyAppeals   PenaltyAppeal[]
  broadcasts       QuoteBroadcast[]
  proposals        QuoteProposal[]
  bookings         Booking[]
  proposalPresets  ServicerProposalPreset[]
  creditLogs       ServicerCreditLog[]
  withdrawals      ServicerWithdrawal[]
  categoryRequests          CategoryRequest[]
  invoices                  Invoice[]
  notifications             Notification[]
  pricingModules            PricingModule[]
  modules                   ServicerModule[]
  waPresets                 ServicerWaPreset[]
  identityChangeRequests    ServicerIdentityChangeRequest[]
  chatSessions              ChatSession[]
  contacts                  ServicerContact[]
  transactions              Transaction[]         @relation("ServicerTransactions")

  @@index([email])
  @@index([isOnline, isBanned])
  @@map("servicers")
}

model ServicerDeposit {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId      String   @unique @map("servicer_id") @db.Uuid
  totalDeposited  Decimal  @default(0) @map("total_deposited") @db.Decimal(10, 2)
  currentBalance  Decimal  @default(0) @map("current_balance") @db.Decimal(10, 2)
  minimumRequired Decimal  @default(100) @map("minimum_required") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@map("servicer_deposits")
}

model ServicerDocument {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId String    @map("servicer_id") @db.Uuid
  docType    DocType   @map("doc_type")
  fileId     String    @map("file_id") @db.Uuid
  status     KycStatus @default(pending)
  adminNote  String?   @map("admin_note")
  verifiedAt DateTime? @map("verified_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@index([servicerId])
  @@map("servicer_documents")
}

model ServicerSchedule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId  String   @map("servicer_id") @db.Uuid
  weekday     Weekday
  timeSlot    TimeSlot @map("time_slot")
  isAvailable Boolean  @default(true) @map("is_available")
  createdAt   DateTime @default(now()) @map("created_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@unique([servicerId, weekday, timeSlot])
  @@map("servicer_schedules")
}

// ── Business contacts (multi-contact per servicer, ≤10, §6) ───────────────────

model ServicerContact {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId       String   @map("servicer_id") @db.Uuid
  contactPerson    String   @map("contact_person")
  number           String?
  email            String?
  isPrimary        Boolean  @default(false) @map("is_primary")
  visibleToCustomer Boolean @default(false) @map("visible_to_customer")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@index([servicerId])
  @@map("business_contacts")
}

model ServicerService {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId               String    @map("servicer_id") @db.Uuid
  categoryId               String    @map("category_id") @db.Uuid
  title                    String
  // SP-3 REDESIGN 2026-06-25: internal servicer reference label (not customer-facing).
  label                    String?   @map("label")
  description              String?
  // SP-3 REDESIGN: proposal text template. Auto-accept fires this; manual can load + edit.
  proposalPreset           String?   @map("proposal_preset")
  // Optional listing photo (S3 file URL). Falls back to the category image on cards.
  imageUrl                 String?   @map("image_url")
  // SP-3: listing visibility. true = Active (customer-visible), false = Draft.
  published                Boolean   @default(true)
  servicerSku              String?   @map("servicer_sku")
  basePrice                Decimal   @map("base_price") @db.Decimal(10, 2)
  priceType                PriceType @default(fixed) @map("price_type")
  // SP-3 §10: listing creation path. 'simple' = one-screen flat listing; 'advanced' = 3-step wizard (modules + per-option pricing + auto-accept).
  listingMode              String    @default("simple") @map("listing_mode")
  modifiers                Json?
  taxMode                  TaxMode   @default(none) @map("tax_mode")
  taxName                  String?   @map("tax_name")
  taxRate                  Decimal?  @map("tax_rate") @db.Decimal(5, 2)
  estimatedDurationMinutes Int       @default(60) @map("estimated_duration_minutes")
  // Servicer's travel fee for this listing (RM). Must be >= effective category baseline.
  travelFee                Decimal?  @map("travel_fee") @db.Decimal(10, 2)
  // Servicer's cleaning supplies fee (RM). Used by Home Cleaning listings only.
  suppliesFee              Decimal?  @map("supplies_fee") @db.Decimal(10, 2)
  // When true, this listing requires an on-site inspection before a real quote is possible.
  requiresInspection       Boolean   @default(false) @map("requires_inspection")
  // Servicer's free-text procedure steps shown to the customer.
  procedure                String?
  autoAccept               Boolean   @default(false) @map("auto_accept")
  // SP-3 §10.2 step 3: optional message shown to the customer when this listing auto-accepts.
  autoAcceptMessage        String?   @map("auto_accept_message")
  autoAcceptConditions     Json?     @map("auto_accept_conditions")
  autoAcceptPresetId       String?   @map("auto_accept_preset_id") @db.Uuid
  fieldRequirements        Json?     @map("field_requirements")
  moduleRefs               Json      @default("[]") @map("module_refs")
  serviceChargeRate        Decimal?  @map("service_charge_rate") @db.Decimal(5, 4)
  taxInclusive             Boolean?  @map("tax_inclusive")
  sstApplies               Boolean?  @map("sst_applies")
  deletedAt                DateTime? @map("deleted_at")
  createdAt                DateTime  @default(now()) @map("created_at")
  updatedAt                DateTime  @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@unique([servicerId, servicerSku])
  @@index([categoryId])
  @@map("servicer_services")
}

// ──────────────────────────────────────────────────────────────────────────────
// Block 2.5 — Pricing modules (servicer-owned reusable library, §19)
// ──────────────────────────────────────────────────────────────────────────────

model PricingModule {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId        String   @map("servicer_id") @db.Uuid
  label             String
  defaultPrice      Decimal  @map("default_price") @db.Decimal(10, 2)
  taxable           Boolean  @default(true)
  serviceChargeable Boolean  @default(true) @map("service_chargeable")
  categoryId        String?  @map("category_id")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@index([servicerId])
  @@map("pricing_modules")
}

// ──────────────────────────────────────────────────────────────────────────────
// Block 2.6 — Servicer modules (SP-3 first-class reusable priced item library)
// First-class replacement for the ad-hoc PricingModule/moduleRefs UX. PricingModule
// is kept for now; reconciliation/migration is Phase 2.
// 2026-06-25: extended with questionKey, optionValue, durationMin per SP-3 redesign §17.
// Each module maps a category question answer to a price+duration+SKU.
// ──────────────────────────────────────────────────────────────────────────────

model ServicerModule {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId        String   @map("servicer_id") @db.Uuid
  name              String
  questionKey       String?  @map("question_key")
  optionValue       String?  @map("option_value")
  price             Decimal  @db.Decimal(10, 2)
  durationMin       Int?     @map("duration_min")
  sku               String?
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@index([servicerId])
  @@map("business_modules")
}

// ──────────────────────────────────────────────────────────────────────────────
// Block 2.7 — Servicer WhatsApp message presets (SP-3 dispatch)
// Reusable wa.me message templates a servicer can fire at a customer from a won
// job card. Body carries {name}/{orderId}/{eta} placeholders interpolated client-side.
// ──────────────────────────────────────────────────────────────────────────────

model ServicerWaPreset {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicerId        String   @map("servicer_id") @db.Uuid
  label             String
  body              String   @db.Text
  active            Boolean  @default(true)
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  servicer Servicer @relation(fields: [servicerId], references: [id])

  @@index([servicerId])
  @@map("servicer_wa_presets")
}

model Category {
  id                            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                          String
  slug                          String    @unique
  icon                          String?
  imageUrl                      String?   @map("image_url")
  parentCategoryId              String?   @map("parent_category_id") @db.Uuid
  defaultPriceSuggestion        Decimal?  @map("default_price_suggestion") @db.Decimal(10, 2)
  defaultEstimatedDurationMinutes Int?    @map("default_estimated_duration_minutes")
  // Per-category custom questions shown in the quote form's Details step.
  // Array of { key, label, type: 'checkbox'|'radio'|'text', required,
  // description?, options?: [{ value, label }], maxSelect?, minSelect?, showIf? }.
  questionSchema                Json?     @map("question_schema")
  allowedTimeSlots              String[]  @default(["morning","noon","afternoon","evening","night"]) @map("allowed_time_slots")
  deletedAt                     DateTime? @map("deleted_at")
  published                     Boolean   @default(false)
  bannerUrl                     String?   @map("banner_url")
  cardColor                     String?   @map("card_color")
  description                   String?
  // Travel fee baseline for this category (RM). Effective baseline = max(this, overall setting).
  travelFeeBaseline             Decimal?  @map("travel_fee_baseline") @db.Decimal(10, 2)
  // Supplies fee baseline for this category (RM). Used by Home Cleaning cleaning_supplies question.
  suppliesFeeBaseline           Decimal?  @map("supplies_fee_baseline") @db.Decimal(10, 2)
  // When true, a servicer listing under this category requires an on-site inspection before a real quote.
  requiresInspection            Boolean   @default(false) @map("requires_inspection")
  // Optional free-text procedure shown to the customer (e.g. "1. Inspect 2. Clean 3. Test").
  procedure                     String?
  // When true, the quote form shows the optional photo upload for this category.
  photosEnabled                 Boolean   @default(false) @map("photos_enabled")
  createdAt                     DateTime  @default(now()) @map("created_at")
  updatedAt                     DateTime  @updatedAt @map("updated_at")

  parent        Category?         @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children      Category[]        @relation("CategoryHierarchy")
  services      ServicerService[]
  quoteRequests QuoteRequest[]
  servicers     Servicer[]        @relation("ServicerCategory")
  feeRules      FeeRule[]          @relation("CategoryFeeRule")

  @@map("categories")
}

