  preferredDate    DateTime     @map("preferred_date")
  propertyType     String?      @map("property_type")
  budgetMin        Decimal?     @map("budget_min") @db.Decimal(10, 2)
  budgetMax        Decimal?     @map("budget_max") @db.Decimal(10, 2)
  paymentMode      PaymentMode  @map("payment_mode")
  // Customer's pay_later settlement choice (credit | cash), captured at quote
  // request time and carried through to booking — so proposal-select does not
  // re-ask. Null for pay_now (decided at the pay step) and legacy rows.
  settlementMethod SettlementMethod? @map("settlement_method")
  tipAmount        Decimal?     @map("tip_amount") @db.Decimal(10, 2)
  deadlineMode     DeadlineMode @map("deadline_mode")
  proposalDeadline DateTime     @map("proposal_deadline")
  servicerDeadline DateTime     @map("servicer_deadline")
  notes            String?
  promoCode        String?      @map("promo_code")
  // Answers to the category's custom questions — { [questionKey]: string | string[] }.
  serviceDetails   Json?        @map("service_details")
  status           QuoteStatus  @default(open)
  parentQuoteId    String?      @map("parent_quote_id") @db.Uuid
  lat              Float?
  lng              Float?
  isUrgent         Boolean      @default(false) @map("is_urgent")
  urgentFee        Decimal?     @db.Decimal(10, 2) @map("urgent_fee")
  images           String[]     @default([]) @map("images")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id])
  category  Category         @relation(fields: [categoryId], references: [id])
  address   UserAddress      @relation(fields: [addressId], references: [id])
  parent    QuoteRequest?    @relation("QuoteRepost", fields: [parentQuoteId], references: [id])
  reposts   QuoteRequest[]   @relation("QuoteRepost")
  proposals QuoteProposal[]
  broadcasts QuoteBroadcast[]
  booking   Booking?
  discountCode DiscountCode?

  @@index([userId, status])
  @@index([categoryId, status])
  @@map("quote_requests")
}

