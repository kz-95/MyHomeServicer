{
  "name": "myhomeservicer-backend",
  "version": "1.0.0",
  "private": true,
  "description": "My Home Servicer marketplace - Express + TypeScript REST API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "postinstall": "prisma generate",
    "start": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "lint": "eslint \"src/**/*.ts\"",
    "typecheck:seed": "tsc -p tsconfig.seed.json",
    "test": "jest --passWithNoTests",
    "test:e2e": "cross-env RUN_E2E=1 jest --passWithNoTests",
    "seed": "npm run typecheck:seed && ts-node --transpile-only prisma/seed/seed.ts",
    "seed:test": "npm run typecheck:seed && ts-node --transpile-only prisma/seed/seed-test.ts",
    "unseed": "ts-node --transpile-only prisma/seed/unseed.ts",
    "reseed": "npm run typecheck:seed && ts-node --transpile-only prisma/seed/unseed.ts && ts-node --transpile-only prisma/seed/seed.ts",
    "reseed:test": "npm run typecheck:seed && ts-node --transpile-only prisma/seed/unseed.ts && ts-node --transpile-only prisma/seed/seed-test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy && prisma generate",
    "db:sync": "prisma migrate deploy && prisma generate",
    "db:reset": "prisma migrate reset --force",
    "db:reset-test": "prisma migrate reset --force --skip-seed && prisma generate && npm run seed:test"
  },
  "overrides": {
    "tar": "7.5.15"
  },
  "prisma": {
    "seed": "ts-node --transpile-only prisma/seed/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1057.0",
    "@aws-sdk/s3-request-presigner": "^3.1057.0",
    "@prisma/client": "5.12.1",
    "@socket.io/redis-adapter": "8.3.0",
    "bcryptjs": "2.4.3",
    "bullmq": "^5.77.6",
    "chrono-node": "^2.9.1",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "^4.22.2",
    "express-rate-limit": "7.2.0",
    "express-session": "^1.19.0",
    "express-validator": "7.0.1",
    "googleapis": "^173.0.0",
    "helmet": "7.1.0",
    "ioredis": "5.3.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "^1.10.1",
    "nodemailer": "^8.0.9",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdf-lib": "1.17.1",
    "prisma": "5.12.1",
    "sharp": "0.33.3",
    "socket.io": "^4.8.3",
    "stripe": "^22.1.1",
    "uuid": "^11.1.1",
    "winston": "3.13.0",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/express-session": "^1.19.0",
    "@types/jest": "29.5.12",
    "@types/jsonwebtoken": "9.0.6",
    "@types/morgan": "1.9.9",
    "@types/node": "20.12.7",
    "@types/nodemailer": "^8.0.0",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/supertest": "6.0.2",
    "@types/uuid": "9.0.8",
    "@typescript-eslint/eslint-plugin": "7.7.0",
    "@typescript-eslint/parser": "7.7.0",
    "cross-env": "7.0.3",
    "eslint": "8.57.0",
    "jest": "29.7.0",
    "supertest": "6.3.4",
    "ts-jest": "29.1.2",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.5"
  }
}
