# ─────────────────────────────────────────────────────────────────────────────
# MyServicer — backend environment template
#
# Copy this file to .env and fill in the secrets:
#   cp backend/.env.example backend/.env
#
# .env is gitignored — never commit it.
# This file IS committed (placeholder values only, no real secrets).
#
# Deployment: Railway (backend), Cloudflare Pages (frontend), Cloudflare R2 (files)
# Email: Brevo SMTP (smtp-relay.brevo.com)
# ─────────────────────────────────────────────────────────────────────────────
#
# ── RAILWAY DEPLOYMENT CHECKLIST (set these in service → Variables) ───────────
# Auto-provided by Railway plugins (use a variable reference, not a literal):
#   DATABASE_URL  ← Postgres plugin
#   REDIS_URL     ← Redis plugin
# Always set manually:
#   JWT_SECRET, REFRESH_SECRET   (64-char random hex each)
#   APP_URL                      = the Cloudflare Pages URL for THIS environment
#                                  (used for OAuth callback, email links, socket origin)
# Set per feature you use: S3_*, G_LLM_API_Token/DS_LLM_API_Token,
#   GOOGLE_CLIENT_*, GOOGLE_MAPS_API_KEY, STRIPE_*, SMTP_*, ADMIN_EMAILS.
#
# DEMO instance (separate Railway service + its own Postgres/Redis):
#   - Do NOT set NODE_ENV (leave unset → defaults to development → demo login +
#     seed-admin + /dev/* routes work). Real prod stays locked.
#   - APP_URL = https://myhomeservicer.pages.dev
#   - ADMIN_SEED_EMAIL/PASSWORD/PIN optional (for the demo admin).
# PROD instance:
#   - NODE_ENV=production  (locks demo login, /dev routes, enables rate limiting).
#   - APP_URL = the production Cloudflare URL.
#
# NOTE: CORS is NOT needed when the frontend uses the Cloudflare Pages Function
#   proxy (same-origin). BACKEND_URL is a CLOUDFLARE (frontend) variable, not a
#   backend one — set it per Cloudflare Pages project, not here.
# ─────────────────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────────────────

NODE_ENV=development
PORT=3000
HOST=0.0.0.0                                     # 0.0.0.0 for LAN/Docker, 127.0.0.1 for localhost-only
TZ=Asia/Kuala_Lumpur                             # prevents date-math drift on UTC runners

# ── Frontend / CORS ───────────────────────────────────────────────────────────

APP_URL=http://localhost:4200
CORS_EXTRA_ORIGINS=                              # comma-separated

# ── Database (Railway auto-provides from Postgres plugin) ─────────────────────

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/homeservices

# ── Redis (Railway auto-provides from Redis plugin) ───────────────────────────

REDIS_URL=redis://localhost:6379

# ── Auth / JWT ────────────────────────────────────────────────────────────────

# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-random-64-char-hex-string
REFRESH_SECRET=replace-with-a-different-random-64-char-hex-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Cloudflare R2 (S3-compatible file storage) ───────────────────────────────

S3_BUCKET=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BASE_URL=

# ── AI / LLM ──────────────────────────────────────────────────────────────────

# Primary — Google Gemini (shared across all Gemini models)
G_LLM_API_Token=

# Fallback — DeepSeek
DS_LLM_API_Token=

# ── Google OAuth ──────────────────────────────────────────────────────────────

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
ADMIN_EMAILS=

# ── Demo admin seed (prisma/seed/seed-admin.ts) ──────────────────────────────

ADMIN_SEED_EMAIL=admin@demo.local
ADMIN_SEED_PASSWORD=Demo@2026
ADMIN_SEED_PIN=1234

# ── Google Maps ───────────────────────────────────────────────────────────────

GOOGLE_MAPS_API_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ── Email (Brevo SMTP) ────────────────────────────────────────────────────────

SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=MyHomeServicer <noreply@myhomeservicer.com>

# ── Gmail API (super admin rescue — Tier 3, separate from SMTP) ──────────────

GOOGLE_GMAIL_CLIENT_ID=
GOOGLE_GMAIL_CLIENT_SECRET=
GOOGLE_GMAIL_REFRESH_TOKEN=

# ── CI WhatsApp notifications (Meta Cloud API — GitHub Actions only) ──────────

# Used by .github/workflows/*.yml notify jobs. Not read by Express at runtime.
# Set these as GitHub repo secrets (Settings → Secrets → Actions), not here.
# Free tier: 1000 messages/month.
META_TOKEN=           # from Meta app → WhatsApp → API Setup → Access token
META_PHONE_ID=        # from Meta app → WhatsApp → API Setup → Phone Number ID
META_WHATSAPP_TO=      # your WhatsApp number, e.g. 60123456789 (no +, no spaces)
